{
  "name": "chronos",
  "version": "0.1.0",
  "description": "Chronos - Personal mental health insight system",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/dev.ps1",
    "build": "vite build && electron-builder",
    "build:dir": "vite build && electron-builder --dir",
    "engine:install": "pip install -e ./engine",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.chronos.app",
    "productName": "Chronos",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "engine/**/*",
      "!engine/**/__pycache__",
      "!engine/**/*.pyc"
    ],
    "extraResources": [
      {
        "from": "engine",
        "to": "engine",
        "filter": ["**/*", "!**/__pycache__", "!**/*.pyc"]
      }
    ],
    "win": {
      "target": ["portable", "dir"],
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "Chronos-${version}-portable.exe"
    }
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
